#!/usr/bin/env bash
# ============================================================
# repos - split the current iTerm tab to the Jeenie repos directory
# ============================================================
set -euo pipefail

DIR="$HOME/Documents/code/github/globalprofessionalsearch"

case "${1:-}" in
  -h|--help)
    cat <<EOF
repos - split the current iTerm tab horizontally at the Jeenie repos directory

Usage: repos

  Splits the current iTerm session horizontally and cd's the new pane to
  $DIR (opens a new window if iTerm has none).
EOF
    exit 0
    ;;
esac

if [[ ! -d "$DIR" ]]; then
  echo "repos: directory not found: $DIR" >&2
  exit 1
fi

osascript - "$DIR" <<'APPLESCRIPT'
on run argv
  set targetDir to item 1 of argv
  tell application "iTerm2"
    activate
    if (count of windows) = 0 then
      set newSession to (current session of (create window with default profile))
    else
      tell current session of current window
        set newSession to (split horizontally with default profile)
      end tell
    end if
    tell newSession
      write text "cd " & quoted form of targetDir & " && clear"
    end tell
  end tell
end run
APPLESCRIPT
