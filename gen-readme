#!/usr/bin/env bash
# desc: Regenerate the README "Available Utilities" section from bin/ symlinks
# gen-readme - Regenerate the "Available Utilities" section of README.md
# from the bin/ symlinks. Deterministic; safe to run repeatedly.
#
# Description for each utility is resolved in priority order:
#   1. skills/<name>/SKILL.md  ->  frontmatter "description:"
#   2. target script           ->  a "# desc: ..." header line
#   3. "(undocumented)"

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="$REPO_DIR/bin"
SKILLS_DIR="$REPO_DIR/skills"
README="$REPO_DIR/README.md"
BEGIN='<!-- BEGIN UTILITIES (generated by gen-readme; do not edit by hand) -->'
END='<!-- END UTILITIES -->'

describe() {
  local name="$1" target="$2" d
  if [[ -f "$SKILLS_DIR/$name/SKILL.md" ]]; then
    d="$(sed -n 's/^description:[[:space:]]*//p' "$SKILLS_DIR/$name/SKILL.md" | head -1)"
    [[ -n "$d" ]] && { printf '%s' "$d"; return; }
  fi
  if [[ -f "$target" ]]; then
    d="$(sed -n 's/^#[[:space:]]*desc:[[:space:]]*//p' "$target" | head -1)"
    [[ -n "$d" ]] && { printf '%s' "$d"; return; }
  fi
  printf '(undocumented)'
}

rows=""
for link in "$BIN_DIR"/*; do
  [[ -L "$link" ]] || continue
  name="$(basename "$link")"
  rel="$(readlink "$link")"
  target="$(cd "$BIN_DIR" && cd "$(dirname "$rel")" && pwd)/$(basename "$rel")"
  rows+="- \`$name\` - $(describe "$name" "$target")"$'\n'
done

bodyfile="$(mktemp)"
printf '%s' "$rows" > "$bodyfile"
tmp="$(mktemp)"
awk -v begin="$BEGIN" -v end="$END" -v bodyfile="$bodyfile" '
  $0 == begin { print; while ((getline line < bodyfile) > 0) print line; skip=1; next }
  $0 == end   { print; skip=0; next }
  !skip       { print }
' "$README" > "$tmp"
mv "$tmp" "$README"
rm -f "$bodyfile"

echo "regenerated README utilities section"
