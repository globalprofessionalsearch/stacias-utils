#!/usr/bin/env bash
# summon/test - negative + positive coverage for `summon lint`.
#
# CI only runs `summon lint` against the repo's own (valid) tree, so a
# regression that weakens a rule would keep CI green. This harness builds
# throwaway fixture repos under a temp dir, points a copy of `summon/main` at
# each, and asserts the linter's exit code (and, for failures, the message).
# Run: ./summon/test  (or: bash summon/test).
set -uo pipefail

SELF_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAIN="$SELF_DIR/main"

pass=0 fail=0
ok()   { printf '  ok   - %s\n' "$1"; pass=$((pass+1)); }
bad()  { printf '  FAIL - %s\n' "$1"; fail=$((fail+1)); }

# Build a minimal, fully-valid fixture repo in $1: a utility, an ordinary
# skill, and a code-review skill. All pass lint. Individual tests then
# mutate a copy to trip one rule.
seed_repo() {
  local root="$1"
  mkdir -p "$root/summon" "$root/utilities/good-tool" \
           "$root/skills/stacia-good-skill" "$root/skills/stacia-code-review"
  cp "$MAIN" "$root/summon/main"; chmod +x "$root/summon/main"

  cat > "$root/utilities/good-tool/main" <<'EOF'
#!/usr/bin/env bash
[[ "${1:-}" == "--help" ]] && { echo "good-tool - a valid fixture tool"; exit 0; }
echo run
EOF
  chmod +x "$root/utilities/good-tool/main"

  cat > "$root/skills/stacia-good-skill/SKILL.md" <<'EOF'
---
name: stacia-good-skill
description: A valid fixture skill.
---
body
EOF

  cat > "$root/skills/stacia-code-review/SKILL.md" <<'EOF'
---
name: stacia-code-review
description: A valid fixture code-review skill.
---
body
EOF
}

# run_lint <root> -> sets RC and LINT_OUT
run_lint() { LINT_OUT="$("$1/summon/main" lint 2>&1)"; RC=$?; }

# expect_pass <label> <root>
expect_pass() {
  run_lint "$2"
  if [[ $RC -eq 0 ]]; then ok "$1"; else
    bad "$1 (expected exit 0, got $RC)"; printf '%s\n' "$LINT_OUT" | sed 's/^/      /'
  fi
}

# expect_fail <label> <root> <substring-of-expected-message>
expect_fail() {
  run_lint "$2"
  if [[ $RC -eq 0 ]]; then
    bad "$1 (expected non-zero exit, got 0)"
  elif [[ "$LINT_OUT" != *"$3"* ]]; then
    bad "$1 (exit $RC but message missing: '$3')"; printf '%s\n' "$LINT_OUT" | sed 's/^/      /'
  else
    ok "$1"
  fi
}

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT
# Mint a fresh, isolated fixture repo each call. mktemp -d (not a shared counter)
# because new_repo runs in a command-substitution subshell, where a parent-scope
# counter increment would not persist and every repo would collide.
new_repo() { local r; r="$(mktemp -d "$TMP/repo.XXXXXX")"; seed_repo "$r"; printf '%s' "$r"; }

echo "summon lint fixtures:"

# Baseline: the seeded repo is valid.
r="$(new_repo)"; expect_pass "valid repo passes" "$r"

# --- utility rule (spot check the linter still fires at all) ---
r="$(new_repo)"
sed -i.bak 's/good-tool - a valid fixture tool/no leading synopsis/' "$r/utilities/good-tool/main"
expect_fail "utility bad --help synopsis" "$r" "line 1 of --help must be"

# --- skill rules (spot checks) ---
r="$(new_repo)"
sed -i.bak '/^description: A valid fixture skill\.$/d' "$r/skills/stacia-good-skill/SKILL.md"
expect_fail "skill missing description" "$r" "'description:' must be non-empty"

r="$(new_repo)"
mv "$r/skills/stacia-good-skill" "$r/skills/good-skill"
sed -i.bak 's/^name: stacia-good-skill$/name: good-skill/' "$r/skills/good-skill/SKILL.md"
expect_fail "skill missing stacia- prefix" "$r" "must be prefixed with 'stacia-'"

echo
printf 'summon/test: %d passed, %d failed\n' "$pass" "$fail"
[[ $fail -eq 0 ]]
