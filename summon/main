#!/usr/bin/env bash
# summon - discover and run Stacia's personal utilities and agent skills
#
# The repo holds two kinds of thing, each in its own top-level directory:
#
#   utilities/<name>/main       an executable whose `--help` prints, on line 1,
#                               a man-page-style synopsis: "<name> - <desc>"
#   skills/<name>/SKILL.md       an agent skill, namespaced with the `stacia-`
#                               prefix; its frontmatter `name`/`description`
#                               are the contract.
#
# Both are self-describing: `summon list` harvests utility synopses from
# `main --help` and skill synopses from frontmatter, so there is nothing to
# regenerate. `summon lint` enforces both contracts (skills must be
# `stacia-`-prefixed). Harness-neutral skill content is a best practice (not
# linted). A skill may also ship a workflow-tool `agentType` binding in its own
# dir (e.g. the code-review read-only binding); `summon setup` installs it into
# ~/.pi/agents/ and `summon lint` enforces it is read-only.
# Everything else at the repo root is infrastructure.
#
# Sugar: a leading run of filler words (a an the this that these those up me my
# some) is ignored, so `summon ctx`, `summon the ctx`, and `summon up a ctx` are
# all equivalent. Summon the tools.
set -euo pipefail

# ---------------------------------------------------------------------------
# Locate the repo root by resolving this script through any symlinks (the one
# PATH entry, bin/summon, is a symlink to <repo>/summon/main).
# ---------------------------------------------------------------------------
_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do
  _dir="$(cd -P "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  case "$_self" in /*) : ;; *) _self="$_dir/$_self" ;; esac
done
SELF_DIR="$(cd -P "$(dirname "$_self")" && pwd)"   # <repo>/summon
REPO="$(dirname "$SELF_DIR")"
UTIL_DIR="$REPO/utilities"   # executable utilities:    <name>/main
SKILL_DIR="$REPO/skills"     # agent skills:            <name>/SKILL.md

# Leading filler/incantation words stripped before dispatch (see main()).
FILLER="a an the this that these those up me my some"
# Names that can never be a utility or skill: builtins, filler words, dispatcher.
RESERVED="list lint commit-lint setup help summon $FILLER"

# Every skill must be namespaced with this prefix so it can't shadow (or be
# shadowed by) unrelated definitions in the shared harness directories.
SKILL_PREFIX="stacia-"
# Umbrella symlink name used for pi's run-once install (pi recurses into it).
PI_SKILLS_LINK="stacia-utils"

err()  { printf '%s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }

# Print the names of all utilities (dirs under utilities/ with a `main`), sorted.
utils() {
  local d name
  for d in "$UTIL_DIR"/*/; do
    [[ -d "$d" ]] || continue
    name="$(basename "$d")"
    [[ -f "$d/main" ]] || continue
    printf '%s\n' "$name"
  done | LC_ALL=C sort
}

# Print the names of all skills (dirs under skills/ with a SKILL.md), sorted.
skills() {
  local d name
  for d in "$SKILL_DIR"/*/; do
    [[ -d "$d" ]] || continue
    name="$(basename "$d")"
    [[ -f "$d/SKILL.md" ]] || continue
    printf '%s\n' "$name"
  done | LC_ALL=C sort
}

# Line 1 of a utility's `--help` (its synopsis). Empty if it produced none.
synopsis() {
  local name="$1"
  "$UTIL_DIR/$name/main" --help 2>/dev/null </dev/null | head -n1
}

# A YAML frontmatter field value (name/description) from any file. Empty if absent.
frontmatter_field() {
  local file="$1" key="$2"
  awk -v k="$key" '
    NR==1 && $0!~/^---[[:space:]]*$/ { exit }
    NR>1 && /^---[[:space:]]*$/ { exit }
    NR>1 {
      if (match($0, "^" k ":[[:space:]]*")) {
        print substr($0, RLENGTH+1); exit
      }
    }
  ' "$file"
}

# A skill's frontmatter field value (name/description). Empty if absent.
skill_field() {
  frontmatter_field "$SKILL_DIR/$1/SKILL.md" "$2"
}

# The read-only tool allow-list the stacia-code-review workflow's agentType
# binding must stay within. The fan-out's read-only guarantee rests on that file
# granting no mutating tool, so it is enforced by lint, not just asserted in
# prose. Every name here is non-mutating (read/search only); pi's real search
# tools are ffgrep/fffind, the generic grep/find/ls are tolerated for portability.
READONLY_TOOLS="read grep find ls ffgrep fffind structured_output"
# The workflow read-only agentType binding this repo ships, and where `summon
# setup` installs it so the `workflow` tool resolves it (user scope).
REVIEW_RO_BINDING="$SKILL_DIR/stacia-code-review/stacia-review-readonly.md"
PI_AGENTS_DIR="$HOME/.pi/agents"

# ---------------------------------------------------------------------------
# Builtins
# ---------------------------------------------------------------------------
cmd_help() {
  cat <<EOF
summon - discover and run Stacia's personal utilities and agent skills

Usage:
  summon list                    List every utility and skill with its synopsis
  summon [filler] <name> [args]  Run a utility (leading a/an/the/this/that/
                                 these/those/up/me/my/some are optional sugar)
  summon [filler] <name> --help  Show a utility's full help
  summon lint                    Enforce the utility + skill contracts (CI + hook)
  summon commit-lint <file|->    Validate a Conventional Commits message
  summon setup                   Configure hooks + skills, print shell-rc hints
  summon help | --help           Show this help

Utilities: utilities/<name>/main (\`--help\` line 1 is "<name> - <desc>").
Skills:    skills/<name>/SKILL.md (stacia-prefixed frontmatter contract).
Run \`summon list\`.
EOF
}

cmd_list() {
  local name syn missing=0 desc

  echo "Utilities:"
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    syn="$(synopsis "$name" || true)"
    if [[ -z "$syn" ]]; then
      printf '  %-18s (no --help synopsis; run: summon lint)\n' "$name"
      missing=1
    else
      printf '  %s\n' "$syn"
    fi
  done < <(utils)

  echo
  echo "Skills:"
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    desc="$(skill_field "$name" description || true)"
    if [[ -z "$desc" ]]; then
      printf '  %-18s (no description; run: summon lint)\n' "$name"
      missing=1
    else
      printf '  %s - %s\n' "$name" "$desc"
    fi
  done < <(skills)

  return $missing
}

# ---------------------------------------------------------------------------
# Linter: hard-ass enforcement of the utility contract.
# ---------------------------------------------------------------------------
cmd_lint() {
  local fail=0 name kebab='^[a-z0-9]+(-[a-z0-9]+)*$'

  # No stray executables loose at the repo root: all code lives in its own dir.
  local f
  for f in "$REPO"/*; do
    [[ -f "$f" && -x "$f" ]] || continue
    err "LINT: stray executable at repo root: $(basename "$f") (move it into utilities/<name>/main)"
    fail=1
  done

  # Every directory under utilities/ must be a conforming utility.
  local d
  for d in "$UTIL_DIR"/*/; do
    [[ -d "$d" ]] || continue
    name="$(basename "$d")"

    if [[ ! "$name" =~ $kebab ]]; then
      err "LINT: $name: name must be kebab-case ([a-z0-9] and single hyphens)"; fail=1
    fi
    case " $RESERVED " in *" $name "*)
      err "LINT: $name: reserved name (clashes with a summon builtin)"; fail=1 ;;
    esac

    if [[ ! -e "$d/main" ]]; then
      err "LINT: $name: no entrypoint (expected $name/main)"; fail=1; continue
    fi
    if [[ ! -f "$d/main" || ! -x "$d/main" ]]; then
      err "LINT: $name: main must be an executable file (chmod +x $name/main)"; fail=1; continue
    fi
    if ! head -c2 "$d/main" | grep -q '^#!'; then
      err "LINT: $name: main must start with a shebang (#!...)"; fail=1
    fi

    # The contract: `main --help` exits 0 and prints "<name> - <desc>" on line 1.
    local out rc line1
    out="$("$d/main" --help 2>/dev/null </dev/null)" && rc=0 || rc=$?
    if [[ $rc -ne 0 ]]; then
      err "LINT: $name: 'main --help' must exit 0 (got $rc)"; fail=1
    fi
    line1="$(printf '%s\n' "$out" | head -n1)"
    if [[ -z "$line1" ]]; then
      err "LINT: $name: 'main --help' printed nothing to stdout"; fail=1
    elif [[ "$line1" != "$name - "* || "$line1" == "$name - " ]]; then
      err "LINT: $name: line 1 of --help must be '$name - <description>' (got: ${line1:-<empty>})"
      fail=1
    fi
  done

  # Every directory under skills/ must be a conforming skill.
  # (Harness-neutral content is a best practice, not linted — see CONTRIBUTING.md.)
  for d in "$SKILL_DIR"/*/; do
    [[ -d "$d" ]] || continue
    name="$(basename "$d")"

    if [[ ! "$name" =~ $kebab ]]; then
      err "LINT: skill $name: name must be kebab-case ([a-z0-9] and single hyphens)"; fail=1
    fi
    if [[ "$name" != "$SKILL_PREFIX"?* ]]; then
      err "LINT: skill $name: name must be prefixed with '$SKILL_PREFIX' (e.g. ${SKILL_PREFIX}$name)"; fail=1
    fi
    case " $RESERVED " in *" $name "*)
      err "LINT: skill $name: reserved name (clashes with a summon builtin)"; fail=1 ;;
    esac

    if [[ ! -f "$d/SKILL.md" ]]; then
      err "LINT: skill $name: missing entrypoint (expected skills/$name/SKILL.md)"; fail=1; continue
    fi
    if [[ "$(head -n1 "$d/SKILL.md")" != "---" ]]; then
      err "LINT: skill $name: SKILL.md must open with a YAML frontmatter block (---)"; fail=1
    fi
    local fname fdesc
    fname="$(skill_field "$name" name || true)"
    fdesc="$(skill_field "$name" description || true)"
    if [[ "$fname" != "$name" ]]; then
      err "LINT: skill $name: frontmatter 'name:' must equal '$name' (got: ${fname:-<empty>})"; fail=1
    fi
    if [[ -z "$fdesc" ]]; then
      err "LINT: skill $name: frontmatter 'description:' must be non-empty"; fail=1
    fi
  done

  # The stacia-code-review workflow's read-only agentType binding: if present, it
  # must be a valid, stacia-prefixed definition granting only non-mutating tools.
  # The fan-out's read-only guarantee depends on this, so enforce it here.
  if [[ -e "$REVIEW_RO_BINDING" ]]; then
    if [[ "$(head -n1 "$REVIEW_RO_BINDING")" != "---" ]]; then
      err "LINT: review binding: $REVIEW_RO_BINDING must open with a YAML frontmatter block (---)"; fail=1
    fi
    local bname btools tool
    bname="$(frontmatter_field "$REVIEW_RO_BINDING" name || true)"
    btools="$(frontmatter_field "$REVIEW_RO_BINDING" tools || true)"
    if [[ "$bname" != "$SKILL_PREFIX"?* ]]; then
      err "LINT: review binding: frontmatter 'name:' must be '$SKILL_PREFIX'-prefixed (got: ${bname:-<empty>})"; fail=1
    fi
    # The workflow tool only honors an array (`tools: [a, b]`); a bare comma
    # string parses as a scalar and is silently ignored (no restriction), so
    # require the flow-array form and strip its brackets before splitting.
    if [[ -z "$btools" ]]; then
      err "LINT: review binding: must declare a read-only 'tools:' field (${READONLY_TOOLS// /, })"; fail=1
    elif [[ "$btools" != \[*\] ]]; then
      err "LINT: review binding: 'tools:' must be a YAML array (tools: [${READONLY_TOOLS// /, }]) — a comma string is ignored by the workflow tool"; fail=1
    else
      btools="${btools#\[}"; btools="${btools%\]}"
      for tool in ${btools//,/ }; do
        case " $READONLY_TOOLS " in
          *" $tool "*) ;;
          *) err "LINT: review binding: tool '$tool' not allowed; the binding must be read-only (${READONLY_TOOLS// /, } only)"; fail=1 ;;
        esac
      done
    fi
  fi

  # The dispatcher must obey its own contract too.
  local s
  s="$("$SELF_DIR/main" --help 2>/dev/null </dev/null | head -n1)"
  [[ "$s" == "summon - "* ]] || { err "LINT: summon: own --help line 1 malformed"; fail=1; }

  if [[ $fail -eq 0 ]]; then
    echo "lint OK ($(utils | grep -c . || true) utilities, $(skills | grep -c . || true) skills)"
  fi
  return $fail
}

# ---------------------------------------------------------------------------
# Conventional Commits validator (shared by commit-msg hook and CI).
# ---------------------------------------------------------------------------
cmd_commit_lint() {
  local src="${1:--}" message subject
  local pattern='^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?(!)?: .+'
  if [[ "$src" == "-" ]]; then message="$(cat)"; else message="$(cat "$src")"; fi
  subject="$(printf '%s\n' "$message" | head -n1)"
  if printf '%s' "$subject" | grep -qE "$pattern"; then exit 0; fi
  cat >&2 <<EOF
Commit subject must follow Conventional Commits:

  type(scope?): subject

types: feat fix docs style refactor perf test chore ci build revert

Your subject:
  $subject
EOF
  exit 1
}

# ---------------------------------------------------------------------------
# One-shot setup: hooks + skills + the workflow read-only binding + shell-rc
# hints. Idempotent.
#  - Skills: a single umbrella symlink exposes skills/ to pi recursively.
#  - Workflow binding: the code-review skill's read-only agentType
#    (stacia-review-readonly.md) is symlinked into ~/.pi/agents/ so the
#    pi-dynamic-workflows `workflow` tool resolves it (user scope, any repo).
# ---------------------------------------------------------------------------
cmd_setup() {
  git -C "$REPO" config core.hooksPath .githooks
  echo "✓ git hooks enabled (core.hooksPath=.githooks)"

  local pi="$HOME/.pi/agent/skills" link
  mkdir -p "$pi"

  # --- pi: run-once. pi discovers SKILL.md dirs recursively, so a single
  # umbrella symlink to the whole skills/ dir exposes every current and future
  # skill. Adding a skill to the repo needs no re-run.
  # First remove any prior per-skill symlinks we planted into pi's root.
  for link in "$pi"/*; do
    [[ -L "$link" ]] || continue
    case "$(readlink "$link")" in
      "$SKILL_DIR"/*) rm -f "$link"; echo "✓ pi: removed per-skill link $(basename "$link")" ;;
    esac
  done
  ln -sfn "$SKILL_DIR" "$pi/$PI_SKILLS_LINK"
  echo "✓ pi: skills linked once ($PI_SKILLS_LINK -> skills/); new skills auto-discovered"

  # --- workflow read-only binding: symlink the code-review skill's agentType
  # definition into ~/.pi/agents/, where the pi-dynamic-workflows `workflow` tool
  # resolves agentType names at user scope (so it applies in any repo under
  # review). This is what makes the review fan-out tool-level read-only.
  if [[ -e "$REVIEW_RO_BINDING" ]]; then
    mkdir -p "$PI_AGENTS_DIR"
    ln -sfn "$REVIEW_RO_BINDING" "$PI_AGENTS_DIR/$(basename "$REVIEW_RO_BINDING")"
    echo "✓ workflow: read-only binding linked ($(basename "$REVIEW_RO_BINDING") -> ~/.pi/agents/)"
  fi

  # --- claude: Claude Code is no longer a wired harness (the code-review skill
  # now requires the pi-only `workflow` tool from pi-dynamic-workflows). Prune any
  # repo-owned symlinks a prior `summon setup` planted into ~/.claude/skills so
  # Claude doesn't keep silently loading a now-incompatible skill. One-time.
  local claude="$HOME/.claude/skills" pruned=0
  if [[ -d "$claude" ]]; then
    for link in "$claude"/*; do
      [[ -L "$link" ]] || continue
      case "$(readlink "$link")" in
        "$SKILL_DIR"/*)
          rm -f "$link"; pruned=1
          echo "✓ claude: pruned stale link $(basename "$link") (Claude support dropped)" ;;
      esac
    done
  fi
  [[ $pruned -eq 0 ]] && echo "✓ claude: nothing to prune (no repo-owned links)"

  cat <<EOF

Add this line to your shell rc (once):

  export PATH="$REPO/bin:\$PATH"

That puts \`summon\` on PATH.

Then: summon list
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
main() {
  # Sugar: strip a leading run of filler words so `summon up the ctx` == `summon
  # ctx`. Remember what we stripped so an all-filler call can echo it back.
  local stripped=""
  while [[ $# -gt 0 ]]; do
    case " $FILLER " in
      *" $1 "*) stripped="${stripped:+$stripped }$1"; shift ;;
      *)        break ;;
    esac
  done
  if [[ -n "$stripped" && $# -eq 0 ]]; then
    err "summon $stripped what?"
    cmd_help
    exit 0
  fi
  local cmd="${1:-help}"
  case "$cmd" in
    help|-h|--help) cmd_help ;;
    list)           shift; cmd_list "$@" ;;
    lint)           shift; cmd_lint "$@" ;;
    commit-lint)    shift; cmd_commit_lint "$@" ;;
    setup)          shift; cmd_setup "$@" ;;
    *)
      if [[ -x "$UTIL_DIR/$cmd/main" ]]; then
        shift; exec "$UTIL_DIR/$cmd/main" "$@"
      fi
      err "summon: unknown utility or command: $cmd"
      err "Run 'summon list' to see what's available."
      exit 127
      ;;
  esac
}

main "$@"
