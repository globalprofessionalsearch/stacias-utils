{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "stacia-code-review config",
  "type": "object",
  "required": ["workflow", "reviewer", "reconciler", "synthesis", "models"],
  "additionalProperties": false,
  "properties": {
    "workflow": {
      "type": "object",
      "required": ["maxRounds", "roundTimeoutMs", "concurrency", "agentRetries"],
      "additionalProperties": false,
      "properties": {
        "maxRounds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum review rounds per perspective (K)"
        },
        "roundTimeoutMs": {
          "type": "integer",
          "minimum": 10000,
          "maximum": 300000,
          "description": "Timeout per round in milliseconds"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum concurrent agents"
        },
        "agentRetries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Retry attempts for recoverable agent failures"
        }
      }
    },
    "reviewer": {
      "type": "object",
      "required": ["maxFindings", "perspectives"],
      "additionalProperties": false,
      "properties": {
        "maxFindings": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Maximum findings per reviewer"
        },
        "perspectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["correctness", "security", "performance", "api-contract", "tests", "adr"]
          },
          "description": "Review perspectives to run"
        }
      }
    },
    "reconciler": {
      "type": "object",
      "required": ["minSeams", "maxSeams"],
      "additionalProperties": false,
      "properties": {
        "minSeams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Minimum seams (floor forces diligence)"
        },
        "maxSeams": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum seams (cap forces coarsening)"
        }
      }
    },
    "synthesis": {
      "type": "object",
      "required": ["followUpThreshold"],
      "additionalProperties": false,
      "properties": {
        "followUpThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "description": "Major/Blocker count that triggers follow-up recommendation"
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "description": "Per-role model overrides. null = use host session model.",
      "properties": {
        "default": { "type": ["string", "null"], "description": "Fallback model for any role without its own override" },
        "orienteer": { "type": ["string", "null"] },
        "reconciler": { "type": ["string", "null"] },
        "reviewer": { "type": ["string", "null"] },
        "synthesizer": { "type": ["string", "null"] },
        "verifier": { "type": ["string", "null"] }
      }
    }
  }
}
