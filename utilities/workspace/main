#!/usr/bin/env bash
# ============================================================
# workspace (shell wrapper)
#
# Finds iTerm2's bundled Python and runs the provisioner.
# ============================================================

set -euo pipefail

case "${1:-}" in
  -h|--help)
    cat <<'EOF'
workspace - open an iTerm2 workspace centered on the current directory

Usage: workspace [project-name]

  project-name  Name for the workspace. If omitted, you'll be prompted.

  Example: workspace my-api
EOF
    exit 0
    ;;
esac

# If no project name supplied, prompt interactively
if [[ -z "${1:-}" ]]; then
  current_dir="$(basename "$(pwd)")"
  while true; do
    echo "1) Use current directory name '${current_dir}'"
    echo "2) Enter custom name"
    echo "3) Quit"
    echo
    read -rp "Choice: " choice
    case "$choice" in
      1)
        PROJECT_NAME="$current_dir"
        break
        ;;
      2)
        while true; do
          read -rp "Enter project name: " custom_name
          if [[ -n "$custom_name" ]]; then
            PROJECT_NAME="$custom_name"
            break 2
          fi
          echo "Project name cannot be empty. Try again or press Ctrl+C to cancel."
          echo
        done
        ;;
      3)
        echo "Cancelled."
        exit 0
        ;;
      *)
        echo "Invalid choice. Please enter 1, 2, or 3."
        echo
        ;;
    esac
  done
else
  PROJECT_NAME="$1"
fi

# Find iTerm2's bundled Python runtime (note: path has a space)
ITERM2_BASE="$HOME/Library/Application Support/iTerm2/iterm2env/versions"
ITERM2_PYTHON=$(ls "$ITERM2_BASE"/*/bin/python3 2>/dev/null | sort -V | tail -1)

if [[ -z "$ITERM2_PYTHON" ]]; then
    echo "Error: iTerm2 Python runtime not found."
    echo "Install it via: iTerm2 menu → Scripts → Manage → Install Python Runtime"
    exit 1
fi

# Find the provisioner script (same directory as this wrapper)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROVISIONER="$SCRIPT_DIR/workspace.py"

if [[ ! -f "$PROVISIONER" ]]; then
    echo "Error: workspace.py not found in $SCRIPT_DIR"
    exit 1
fi

# Pass project name and current directory to provisioner
exec "$ITERM2_PYTHON" "$PROVISIONER" "$PROJECT_NAME" "$(pwd)"
