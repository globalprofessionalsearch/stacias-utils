#!/usr/bin/env python3
"""
gcs-watch - Poll a GCS bucket and send SMS alerts for new folders
"""

import argparse
import os
import smtplib
import subprocess
import sys
import time
from email.mime.text import MIMEText
from pathlib import Path


CARRIERS = {
    "verizon": "vtext.com",
    "att": "txt.att.net",
    "tmobile": "tmomail.net",
    "sprint": "messaging.sprintpcs.com",
}


def load_gmail_creds():
    """Load Gmail credentials from digester's .env file."""
    env_path = Path(__file__).parent.parent.parent / "utilities" / "digester" / ".env"
    if not env_path.exists():
        print(f"Error: {env_path} not found", file=sys.stderr)
        sys.exit(1)
    
    email = None
    password = None
    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if line.startswith("EMAIL="):
                email = line.split("=", 1)[1]
            elif line.startswith("APP_PASSWORD="):
                password = line.split("=", 1)[1]
    
    if not email or not password:
        print("Error: EMAIL or APP_PASSWORD not found in digester .env", file=sys.stderr)
        sys.exit(1)
    
    return email, password


def send_sms(phone, carrier, message, gmail_email, gmail_password):
    """Send SMS via email-to-SMS gateway."""
    if carrier not in CARRIERS:
        print(f"Error: unknown carrier '{carrier}'", file=sys.stderr)
        sys.exit(1)
    
    to_addr = f"{phone}@{CARRIERS[carrier]}"
    msg = MIMEText(message)
    msg["From"] = gmail_email
    msg["To"] = to_addr
    msg["Subject"] = ""  # SMS gateways ignore subject
    
    try:
        with smtplib.SMTP_SSL("smtp.gmail.com", 465) as smtp:
            smtp.login(gmail_email, gmail_password)
            smtp.send_message(msg)
    except Exception as e:
        print(f"Error sending SMS: {e}", file=sys.stderr)
        raise


def list_folders(bucket_path):
    """List all folders in the bucket using gsutil."""
    try:
        result = subprocess.run(
            ["gsutil", "ls", "-r", bucket_path],
            capture_output=True,
            text=True,
            check=True
        )
        # Keep only directory entries (end with / or :)
        folders = set()
        for line in result.stdout.splitlines():
            line = line.strip()
            if not line:
                continue
            # Lines ending with : are directory headers, extract the path
            if line.endswith(":"):
                folders.add(line[:-1] + "/")
            # Lines ending with / are also folders
            elif line.endswith("/"):
                folders.add(line)
        return folders
    except subprocess.CalledProcessError as e:
        print(f"Error listing bucket: {e.stderr}", file=sys.stderr)
        return set()


def load_state(state_file):
    """Load seen folders from state file."""
    if not os.path.exists(state_file):
        return set()
    with open(state_file) as f:
        return set(line.strip() for line in f if line.strip())


def save_state(state_file, folders):
    """Save seen folders to state file."""
    with open(state_file, "w") as f:
        for path in sorted(folders):
            f.write(path + "\n")


def watch(bucket_path, phone, carrier, interval, state_file):
    """Poll bucket and send alerts for new folders."""
    gmail_email, gmail_password = load_gmail_creds()
    seen = load_state(state_file)
    
    print(f"Watching {bucket_path} every {interval}s")
    print(f"Alerts to: {phone}@{CARRIERS[carrier]}")
    print(f"State: {state_file}")
    print(f"Press Ctrl-C to stop\n")
    
    # Initial scan - don't alert on startup
    if not seen:
        print("Initial scan...")
        seen = list_folders(bucket_path)
        save_state(state_file, seen)
        print(f"Found {len(seen)} existing folders\n")
    
    try:
        while True:
            current = list_folders(bucket_path)
            new_folders = current - seen
            
            if new_folders:
                # Batch all new folders into one SMS
                count = len(new_folders)
                folder_list = "\n".join(sorted(new_folders)[:10])  # Max 10 in SMS
                if count > 10:
                    folder_list += f"\n... and {count - 10} more"
                
                message = f"GCS: {count} new folder{'s' if count > 1 else ''}\n{folder_list}"
                
                print(f"NEW FOLDERS: {count}")
                for path in sorted(new_folders):
                    print(f"  {path}")
                
                try:
                    send_sms(phone, carrier, message, gmail_email, gmail_password)
                    print(f"  → SMS sent")
                except Exception as e:
                    print(f"  → SMS failed: {e}")
                
                seen = current
                save_state(state_file, seen)
            
            time.sleep(interval)
            
    except KeyboardInterrupt:
        print("\nStopped")


def main():
    parser = argparse.ArgumentParser(
        description="Poll a GCS bucket and send SMS alerts for new folders",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  gcs-watch gs://my-bucket 2539510932 verizon
  gcs-watch gs://my-bucket/path 5551234567 att --interval 30
  gcs-watch gs://my-bucket 2539510932 verizon --state /tmp/my-watch.state

Supported carriers: verizon, att, tmobile, sprint
Uses Gmail credentials from digester/.env
Tracks folders only (not individual files)
        """
    )
    
    parser.add_argument("bucket", help="GCS bucket path (gs://...)")
    parser.add_argument("phone", help="Phone number (digits only)")
    parser.add_argument("carrier", choices=list(CARRIERS.keys()), 
                       help="Carrier for SMS gateway")
    parser.add_argument("--interval", type=int, default=60, 
                       help="Poll interval in seconds (default: 60)")
    parser.add_argument("--state", 
                       default=os.path.expanduser("~/.gcs-watch.state"),
                       help="State file path (default: ~/.gcs-watch.state)")
    
    if len(sys.argv) == 1 or sys.argv[1] in ("-h", "--help"):
        print("gcs-watch - Poll a GCS bucket and send SMS alerts for new folders")
        parser.print_help()
        sys.exit(0)
    
    args = parser.parse_args()
    
    # Validate phone number
    if not args.phone.isdigit():
        print("Error: phone must be digits only", file=sys.stderr)
        sys.exit(1)
    
    # Validate bucket path
    if not args.bucket.startswith("gs://"):
        print("Error: bucket must start with gs://", file=sys.stderr)
        sys.exit(1)
    
    watch(args.bucket, args.phone, args.carrier, args.interval, args.state)


if __name__ == "__main__":
    main()
