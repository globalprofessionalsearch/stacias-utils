#!/usr/bin/env bash
# commit-lint - Validate a commit message / PR title against Conventional
# Commits. Single source of truth shared by the commit-msg git hook and the
# GitHub Actions PR check. (Repo tooling; exempt from the utility layout.)
#
# Usage:
#   commit-lint <file>     # validate first line of a commit-message file
#   commit-lint -          # validate message read from stdin
set -euo pipefail

PATTERN='^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\(.+\))?: .+'

src="${1:--}"
if [[ "$src" == "-" ]]; then
  message="$(cat)"
else
  message="$(cat "$src")"
fi
subject="$(printf '%s\n' "$message" | head -n1)"

if printf '%s' "$subject" | grep -qE "$PATTERN"; then
  exit 0
fi

cat >&2 <<EOF
❌ Message must follow Conventional Commits format:

  type(scope?): subject

Types:
  feat:     New feature
  fix:      Bug fix
  docs:     Documentation changes
  style:    Code style/formatting
  refactor: Code refactoring
  perf:     Performance improvements
  test:     Tests
  chore:    Maintenance
  ci:       CI/CD changes
  build:    Build system changes
  revert:   Revert a commit

Examples:
  feat: add bash_presentation utility
  fix(ctx): handle missing kubectl config
  docs: update README with usage examples

Your message:
  $subject
EOF
exit 1
