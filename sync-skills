#!/usr/bin/env bash
# sync-skills - Deterministically sync skills from this repo (the leader)
# to pi and Claude Code.
#
# Source of truth: <repo>/skills/<name>/SKILL.md  (pi's native format)
#   - pi:     symlink ~/.pi/agent/skills/<name> -> <repo>/skills/<name>
#   - Claude: generate ~/.claude/skills/<name>.md from SKILL.md
#
# Idempotent. Prunes only the artifacts it manages. Never touches
# hand-authored skills it didn't create.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$REPO_DIR/skills"
PI_SKILLS="$HOME/.pi/agent/skills"
CLAUDE_SKILLS="$HOME/.claude/skills"
MANIFEST="$CLAUDE_SKILLS/.stacias-utils-managed"

mkdir -p "$PI_SKILLS" "$CLAUDE_SKILLS"

# Collect current skill names from the leader.
declare -a names=()
if compgen -G "$SKILLS_DIR/*/" > /dev/null; then
  for dir in "$SKILLS_DIR"/*/; do
    name="$(basename "$dir")"
    if [[ ! -f "$dir/SKILL.md" ]]; then
      echo "skip: $name (no SKILL.md)" >&2
      continue
    fi
    if ! grep -q '^name:' "$dir/SKILL.md" || ! grep -q '^description:' "$dir/SKILL.md"; then
      echo "FAIL: $name/SKILL.md missing 'name:' or 'description:' frontmatter" >&2
      exit 1
    fi
    names+=("$name")
  done
fi

# --- pi: symlink directories ---
for name in "${names[@]}"; do
  ln -sfn "$SKILLS_DIR/$name" "$PI_SKILLS/$name"
done

# Prune pi symlinks that point into our skills dir but no longer exist.
for link in "$PI_SKILLS"/*; do
  [[ -L "$link" ]] || continue
  target="$(readlink "$link")"
  case "$target" in
    "$SKILLS_DIR"/*)
      base="$(basename "$link")"
      found=0
      for name in "${names[@]}"; do [[ "$name" == "$base" ]] && found=1; done
      [[ $found -eq 0 ]] && rm -f "$link" && echo "pruned pi: $base"
      ;;
  esac
done

# --- Claude: generate flat .md files ---
for name in "${names[@]}"; do
  cp "$SKILLS_DIR/$name/SKILL.md" "$CLAUDE_SKILLS/$name.md"
done

# Prune Claude files we previously generated but are now gone.
if [[ -f "$MANIFEST" ]]; then
  while IFS= read -r old; do
    [[ -z "$old" ]] && continue
    found=0
    for name in "${names[@]}"; do [[ "$name" == "$old" ]] && found=1; done
    if [[ $found -eq 0 ]]; then
      rm -f "$CLAUDE_SKILLS/$old.md" && echo "pruned claude: $old"
    fi
  done < "$MANIFEST"
fi

# Rewrite manifest.
printf '%s\n' "${names[@]}" > "$MANIFEST"

echo "synced ${#names[@]} skill(s): ${names[*]:-<none>}"
