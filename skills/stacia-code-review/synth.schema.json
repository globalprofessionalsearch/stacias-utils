{
  "type": "object",
  "required": [
    "repo",
    "summary",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "repo": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "confidence",
          "theme",
          "perspectives",
          "location",
          "evidence",
          "finding",
          "rationale"
        ],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "Blocker",
              "Major",
              "Minor",
              "Nit"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "High",
              "Medium",
              "Low"
            ]
          },
          "theme": {
            "type": "string"
          },
          "perspectives": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "correctness",
                "security",
                "performance",
                "api-contract",
                "tests"
              ]
            }
          },
          "location": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        }
      }
    }
  }
}
